POSTGRES_DB=ai_company_os
POSTGRES_USER=ai_company_os
POSTGRES_PASSWORD=replace-with-a-strong-password
BACKEND_PORT=8000
WEB_PORT=3000
NEXT_PUBLIC_API_BASE=http://localhost:8000
SCHEDULER_POLL_SECONDS=5

# Use this outside Docker instead of AI_COMPANY_OS_SQLITE_PATH.
AI_COMPANY_OS_DATABASE_URL=postgresql://ai_company_os:replace-with-a-strong-password@localhost:5432/ai_company_os
AI_COMPANY_OS_REDIS_URL=redis://localhost:6379/0

# HTTP auth remains off for local development. Set required=true in production
# and provide either a raw API token through your secrets manager or its SHA-256
# hex digest. Prefer the digest when your platform supports secret hashing.
AI_COMPANY_OS_AUTH_REQUIRED=false
AI_COMPANY_OS_API_TOKEN=
AI_COMPANY_OS_API_TOKEN_SHA256=

# Provider calls are disabled by default. Set both providers to openai to enable live
# generation and pgvector-backed semantic Knowledge search.
AI_COMPANY_OS_MODEL_PROVIDER=local
AI_COMPANY_OS_MODEL_NAME=gpt-4.1-mini
AI_COMPANY_OS_ALLOWED_MODELS=gpt-4.1-mini
AI_COMPANY_OS_EMBEDDING_PROVIDER=disabled
AI_COMPANY_OS_EMBEDDING_MODEL=text-embedding-3-small
AI_COMPANY_OS_PROVIDER_TIMEOUT_SECONDS=60
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
